generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  login         String    @unique
  passwordHash  String
  fullName      String
  role          String    @default("cashier")
  warehouseId   Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  receipts      Receipt[]
  issues        Issue[]
  sales         Sale[]
  returns       Return[]  @relation("ReturnApprover")
  transfers     Transfer[]
  shifts        Shift[]
  cashOps       CashOperation[]
  inventoryCreated Inventory[]
}

model Warehouse {
  id          Int     @id @default(autoincrement())
  name        String
  address     String?
  description String?
  isActive    Boolean @default(true)
  users       User[]
  receipts    Receipt[]
  issues      Issue[]
  sales       Sale[]
  returns     Return[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")
  shifts      Shift[]
  inventories Inventory[]
  stock       Stock[]
  sizeStocks  SizeStock[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]
}

model Supplier {
  id       Int       @id @default(autoincrement())
  name     String
  contact  String?
  phone    String?
  email    String?
  products Product[]
  receipts Receipt[]
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  brand       String?
  gender      String?
  season      String?
  categoryId  Int?
  supplierId  Int?
  salePrice   Decimal  @db.Decimal(12,2) @default(0)
  costPrice   Decimal  @db.Decimal(12,2) @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  category      Category?      @relation(fields: [categoryId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  sizes         ProductSize[]
  receiptItems  ReceiptItem[]
  issueItems    IssueItem[]
  saleItems     SaleItem[]
  returnItems   ReturnItem[]
  transferItems TransferItem[]
  inventoryItems InventoryItem[]
  stock         Stock[]
  stockMovements StockMovement[]
}

model ProductSize {
  id        Int    @id @default(autoincrement())
  productId Int
  size      String
  quantity  Int    @default(0)

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  receiptItems  ReceiptItem[]
  issueItems    IssueItem[]
  saleItems     SaleItem[]
  transferItems TransferItem[]
  inventoryItems InventoryItem[]
  sizeStocks    SizeStock[]
  stockMovements StockMovement[]

  @@unique([productId, size])
}

model SizeStock {
  id          Int     @id @default(autoincrement())
  sizeId      Int
  warehouseId Int
  quantity    Int     @default(0)
  avgCost     Decimal @db.Decimal(12,2) @default(0)
  reserved    Int     @default(0)

  size      ProductSize @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])

  @@unique([sizeId, warehouseId])
}

model Stock {
  id          Int     @id @default(autoincrement())
  productId   Int
  warehouseId Int
  quantity    Int     @default(0)
  avgCost     Decimal @db.Decimal(12,2) @default(0)
  reserved    Int     @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model StockMovement {
  id            Int      @id @default(autoincrement())
  productId     Int
  warehouseId   Int
  sizeId        Int?
  delta         Int
  type          String
  docType       String?
  docId         Int?
  balanceBefore Int
  balanceAfter  Int
  createdAt     DateTime @default(now())

  product Product      @relation(fields: [productId], references: [id])
  size    ProductSize? @relation(fields: [sizeId], references: [id])
}

model Receipt {
  id          Int      @id @default(autoincrement())
  warehouseId Int
  supplierId  Int?
  userId      Int
  status      String   @default("draft")
  notes       String?
  date        DateTime @default(now())

  warehouse Warehouse    @relation(fields: [warehouseId], references: [id])
  supplier  Supplier?    @relation(fields: [supplierId], references: [id])
  user      User         @relation(fields: [userId], references: [id])
  items     ReceiptItem[]
}

model ReceiptItem {
  id          Int     @id @default(autoincrement())
  receiptId   Int
  productId   Int
  sizeId      Int?
  quantity    Int
  costPerUnit Decimal @db.Decimal(12,2) @default(0)

  receipt Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
  size    ProductSize? @relation(fields: [sizeId], references: [id])
}

model Issue {
  id          Int      @id @default(autoincrement())
  warehouseId Int
  userId      Int
  recipient   String?
  status      String   @default("draft")
  notes       String?
  date        DateTime @default(now())

  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
  items     IssueItem[]
}

model IssueItem {
  id        Int @id @default(autoincrement())
  issueId   Int
  productId Int
  sizeId    Int?
  quantity  Int

  issue   Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
  size    ProductSize? @relation(fields: [sizeId], references: [id])
}

model Sale {
  id            Int      @id @default(autoincrement())
  receiptNumber String   @unique
  warehouseId   Int?
  cashierId     Int
  shiftId       Int?
  paymentMethod String   @default("cash")
  subtotal      Decimal  @db.Decimal(12,2) @default(0)
  discount      Decimal  @db.Decimal(12,2) @default(0)
  total         Decimal  @db.Decimal(12,2) @default(0)
  amountPaid    Decimal  @db.Decimal(12,2) @default(0)
  change        Decimal  @db.Decimal(12,2) @default(0)
  createdAt     DateTime @default(now())

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  cashier   User       @relation(fields: [cashierId], references: [id])
  shift     Shift?     @relation(fields: [shiftId], references: [id])
  items     SaleItem[]
  returns   Return[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  sizeId    Int?
  quantity  Int
  salePrice Decimal @db.Decimal(12,2)
  costPrice Decimal @db.Decimal(12,2) @default(0)
  total     Decimal @db.Decimal(12,2) @default(0)

  sale    Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
  size    ProductSize? @relation(fields: [sizeId], references: [id])
}

model Return {
  id            Int      @id @default(autoincrement())
  saleId        Int?
  warehouseId   Int
  shiftId       Int?
  approvedBy    Int?
  reason        String?
  reasonNote    String?
  refundMethod  String?
  refundAmount  Decimal  @db.Decimal(12,2) @default(0)
  condition     String   @default("good")
  stockRestored Boolean  @default(false)
  createdAt     DateTime @default(now())

  sale      Sale?       @relation(fields: [saleId], references: [id])
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])
  shift     Shift?      @relation(fields: [shiftId], references: [id])
  approver  User?       @relation("ReturnApprover", fields: [approvedBy], references: [id])
  items     ReturnItem[]
}

model ReturnItem {
  id          Int     @id @default(autoincrement())
  returnId    Int
  productId   Int
  quantity    Int
  refundPrice Decimal @db.Decimal(12,2) @default(0)

  return  Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Transfer {
  id              Int      @id @default(autoincrement())
  fromWarehouseId Int
  toWarehouseId   Int
  userId          Int
  status          String   @default("draft")
  notes           String?
  createdAt       DateTime @default(now())

  fromWarehouse Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  items         TransferItem[]
}

model TransferItem {
  id          Int  @id @default(autoincrement())
  transferId  Int
  productId   Int
  sizeId      Int?
  sentQty     Int
  receivedQty Int?

  transfer Transfer     @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id])
  size     ProductSize? @relation(fields: [sizeId], references: [id])
}

model Shift {
  id           Int      @id @default(autoincrement())
  warehouseId  Int
  cashierId    Int
  status       String   @default("open")
  openingCash  Decimal  @db.Decimal(12,2) @default(0)
  closingCash  Decimal? @db.Decimal(12,2)
  expectedCash Decimal? @db.Decimal(12,2)
  cashDiff     Decimal? @db.Decimal(12,2)
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  xReportAt    DateTime?
  telegramSent Boolean  @default(false)

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  cashier   User            @relation(fields: [cashierId], references: [id])
  sales     Sale[]
  cashOps   CashOperation[]
  returns   Return[]
}

model CashOperation {
  id          Int      @id @default(autoincrement())
  shiftId     Int
  userId      Int
  type        String
  amount      Decimal  @db.Decimal(12,2)
  description String?
  createdAt   DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model Inventory {
  id          Int       @id @default(autoincrement())
  warehouseId Int
  type        String    @default("full")
  scope       String?
  status      String    @default("draft")
  createdBy   Int
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id])
  createdByUser User            @relation(fields: [createdBy], references: [id])
  items         InventoryItem[]
}

model InventoryItem {
  id          Int     @id @default(autoincrement())
  inventoryId Int
  productId   Int
  sizeId      Int?
  expectedQty Int
  actualQty   Int?
  discrepancy Int?
  action      String?

  inventory Inventory    @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  size      ProductSize? @relation(fields: [sizeId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String?
  entityId  Int?
  data      String?
  createdAt DateTime @default(now())
}

model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  username  String?
  firstName String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
