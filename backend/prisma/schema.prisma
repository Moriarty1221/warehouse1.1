generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  login        String     @unique
  passwordHash String
  fullName     String
  role         String     @default("cashier")
  warehouseId  Int?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  receipts     Receipt[]
  issues       Issue[]
  auditLogs    AuditLog[]
  transfers    Transfer[]
  shifts       Shift[]
  sales        Sale[]
  returns      Return[]
}

model Warehouse {
  id            Int         @id @default(autoincrement())
  name          String
  address       String?
  description   String?
  isActive      Boolean     @default(true)
  users         User[]
  receipts      Receipt[]
  issues        Issue[]
  transfersFrom Transfer[]  @relation("TransferFrom")
  transfersTo   Transfer[]  @relation("TransferTo")
  shifts        Shift[]
  sales         Sale[]
  returns       Return[]
  inventories   Inventory[]
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]
}

model Product {
  id          Int          @id @default(autoincrement())
  sku         String       @unique
  name        String
  brand       String?
  categoryId  Int?
  salePrice   Decimal      @db.Decimal(12,2) @default(0)
  costPrice   Decimal      @db.Decimal(12,2) @default(0)
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  category    Category?    @relation(fields: [categoryId], references: [id])
  sizes       ProductSize[]
  receiptItems ReceiptItem[]
  issueItems   IssueItem[]
  saleItems    SaleItem[]
  returnItems  ReturnItem[]
  transferItems TransferItem[]
  inventoryItems InventoryItem[]
}

model ProductSize {
  id        Int         @id @default(autoincrement())
  productId Int
  size      String
  quantity  Int         @default(0)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model Supplier {
  id       Int       @id @default(autoincrement())
  name     String
  contact  String?
  phone    String?
  email    String?
  receipts Receipt[]
  products Product[]
}

model Receipt {
  id          Int           @id @default(autoincrement())
  warehouseId Int
  supplierId  Int?
  userId      Int
  status      String        @default("draft")
  date        DateTime      @default(now())
  notes       String?
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  supplier    Supplier?     @relation(fields: [supplierId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  items       ReceiptItem[]
}

model ReceiptItem {
  id          Int          @id @default(autoincrement())
  receiptId   Int
  productId   Int
  sizeId      Int?
  quantity    Int
  costPerUnit Decimal      @db.Decimal(12,2) @default(0)
  receipt     Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  size        ProductSize? @relation(fields: [sizeId], references: [id])
}

model Issue {
  id          Int         @id @default(autoincrement())
  warehouseId Int
  userId      Int
  recipient   String?
  status      String      @default("draft")
  date        DateTime    @default(now())
  notes       String?
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  items       IssueItem[]
}

model IssueItem {
  id        Int     @id @default(autoincrement())
  issueId   Int
  productId Int
  sizeId    Int?
  quantity  Int
  issue     Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  size      ProductSize? @relation(fields: [sizeId], references: [id])
}

model Shift {
  id           Int             @id @default(autoincrement())
  warehouseId  Int
  cashierId    Int
  openedAt     DateTime        @default(now())
  closedAt     DateTime?
  openingCash  Decimal         @db.Decimal(12,2) @default(0)
  closingCash  Decimal?        @db.Decimal(12,2)
  expectedCash Decimal?        @db.Decimal(12,2)
  cashDiff     Decimal?        @db.Decimal(12,2)
  status       String          @default("open")
  xReportAt    DateTime?
  telegramSent Boolean         @default(false)
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  cashier      User            @relation(fields: [cashierId], references: [id])
  sales        Sale[]
  cashOps      CashOperation[]
  returns      Return[]
}

model CashOperation {
  id          Int      @id @default(autoincrement())
  shiftId     Int
  type        String
  amount      Decimal  @db.Decimal(12,2)
  description String?
  userId      Int
  createdAt   DateTime @default(now())
  shift       Shift    @relation(fields: [shiftId], references: [id])
}

model Sale {
  id             Int        @id @default(autoincrement())
  receiptNumber  String     @unique
  warehouseId    Int
  cashierId      Int
  shiftId        Int?
  paymentMethod  String     @default("cash")
  subtotal       Decimal    @db.Decimal(12,2)
  discount       Decimal    @db.Decimal(12,2) @default(0)
  total          Decimal    @db.Decimal(12,2)
  amountPaid     Decimal    @db.Decimal(12,2)
  change         Decimal    @db.Decimal(12,2) @default(0)
  status         String     @default("completed")
  telegramSent   Boolean    @default(false)
  idempotencyKey String?    @unique
  createdAt      DateTime   @default(now())
  warehouse      Warehouse  @relation(fields: [warehouseId], references: [id])
  cashier        User       @relation(fields: [cashierId], references: [id])
  shift          Shift?     @relation(fields: [shiftId], references: [id])
  items          SaleItem[]
  returns        Return[]
}

model SaleItem {
  id        Int          @id @default(autoincrement())
  saleId    Int
  productId Int
  sizeId    Int?
  quantity  Int
  salePrice Decimal      @db.Decimal(12,2)
  costPrice Decimal      @db.Decimal(12,2) @default(0)
  discount  Decimal      @db.Decimal(12,2) @default(0)
  total     Decimal      @db.Decimal(12,2)
  sale      Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  size      ProductSize? @relation(fields: [sizeId], references: [id])
}

model Return {
  id            Int          @id @default(autoincrement())
  saleId        Int?
  warehouseId   Int
  shiftId       Int?
  approvedBy    Int?
  reason        String
  reasonNote    String?
  refundMethod  String
  refundAmount  Decimal      @db.Decimal(12,2)
  stockRestored Boolean      @default(false)
  condition     String       @default("good")
  createdAt     DateTime     @default(now())
  sale          Sale?        @relation(fields: [saleId], references: [id])
  warehouse     Warehouse    @relation(fields: [warehouseId], references: [id])
  shift         Shift?       @relation(fields: [shiftId], references: [id])
  approver      User?        @relation(fields: [approvedBy], references: [id])
  items         ReturnItem[]
}

model ReturnItem {
  id          Int          @id @default(autoincrement())
  returnId    Int
  productId   Int
  sizeId      Int?
  quantity    Int
  refundPrice Decimal      @db.Decimal(12,2)
  return      Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  size        ProductSize? @relation(fields: [sizeId], references: [id])
}

model Transfer {
  id              Int            @id @default(autoincrement())
  fromWarehouseId Int
  toWarehouseId   Int
  userId          Int
  confirmedBy     Int?
  status          String         @default("draft")
  notes           String?
  createdAt       DateTime       @default(now())
  sentAt          DateTime?
  receivedAt      DateTime?
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  items           TransferItem[]
}

model TransferItem {
  id              Int      @id @default(autoincrement())
  transferId      Int
  productId       Int
  sizeId          Int?
  sentQty         Int
  receivedQty     Int?
  discrepancy     Int?
  discrepancyNote String?
  transfer        Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  size            ProductSize? @relation(fields: [sizeId], references: [id])
}

model Inventory {
  id          Int             @id @default(autoincrement())
  warehouseId Int
  type        String
  scope       String?
  status      String          @default("draft")
  locksStock  Boolean         @default(true)
  startedAt   DateTime?
  completedAt DateTime?
  createdBy   Int
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  items       InventoryItem[]
}

model InventoryItem {
  id          Int          @id @default(autoincrement())
  inventoryId Int
  productId   Int
  sizeId      Int?
  expectedQty Int
  actualQty   Int?
  discrepancy Int?
  action      String?
  inventory   Inventory    @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  size        ProductSize? @relation(fields: [sizeId], references: [id])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  tableName String
  recordId  Int?
  diff      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  chatId    String   @unique
  username  String?
  firstName String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
