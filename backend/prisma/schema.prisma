generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === Основные модели ===
model User {
  id            Int       @id @default(autoincrement())
  login         String    @unique
  passwordHash  String
  fullName      String
  role          String    @default("cashier")
  warehouseId   Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  receipts      Receipt[]
  issues        Issue[]
  sales         Sale[]
  returns       Return[]
  transfers     Transfer[]
  shifts        Shift[]
  inventoryCreated Inventory[]
}

model Warehouse {
  id          Int     @id @default(autoincrement())
  name        String
  address     String?
  description String?
  isActive    Boolean @default(true)
  users       User[]
  receipts    Receipt[]
  issues      Issue[]
  sales       Sale[]
  returns     Return[]
  transfersFrom Transfer[] @relation("TransferFrom")
  transfersTo   Transfer[] @relation("TransferTo")
  shifts      Shift[]
  inventories Inventory[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category? @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  brand       String?
  gender      String?
  season      String?
  categoryId  Int?
  supplierId  Int?
  salePrice   Decimal  @db.Decimal(12,2) @default(0)
  costPrice   Decimal  @db.Decimal(12,2) @default(0)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  category    Category?  @relation(fields: [categoryId], references: [id])
  supplier    Supplier?  @relation(fields: [supplierId], references: [id])
  sizes       ProductSize[]
  receiptItems ReceiptItem[]
  issueItems   IssueItem[]
  saleItems    SaleItem[]
  returnItems  ReturnItem[]
  transferItems TransferItem[]
  inventoryItems InventoryItem[]
}

model ProductSize {
  id        Int    @id @default(autoincrement())
  productId Int
  size      String
  quantity  Int    @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

// Остальные модели (оставляем как были, но добавляем sizeId где нужно)
model Supplier { ... } // оставь как было

model Receipt { ... }
model ReceiptItem {
  id          Int        @id @default(autoincrement())
  receiptId   Int
  productId   Int
  sizeId      Int?       // ← важно
  quantity    Int
  costPerUnit Decimal    @db.Decimal(12,2) @default(0)
  receipt     Receipt    @relation(fields: [receiptId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
  size        ProductSize? @relation(fields: [sizeId], references: [id])
}

model Issue { ... }
model IssueItem {
  id        Int @id @default(autoincrement())
  issueId   Int
  productId Int
  sizeId    Int?   // ← важно
  quantity  Int
  // ...
}

model Sale { ... }
model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  sizeId    Int?    // ← важно
  quantity  Int
  salePrice Decimal @db.Decimal(12,2)
  costPrice Decimal @db.Decimal(12,2) @default(0)
  // ...
}

model Return { ... }
model ReturnItem { /* аналогично с sizeId */ }

model Transfer { ... }
model TransferItem {
  id          Int @id @default(autoincrement())
  transferId  Int
  productId   Int
  sizeId      Int?   // ← важно
  sentQty     Int
  receivedQty Int?
  // ...
}

model Inventory { ... }
model InventoryItem {
  id          Int @id @default(autoincrement())
  inventoryId Int
  productId   Int
  sizeId      Int?
  expectedQty Int
  actualQty   Int?
  // ...
}
