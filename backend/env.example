# PostgreSQL connection string (Railway auto-provides this)
DATABASE_URL="postgresql://user:password@host:5432/warehouse"

# JWT secret - change this to something random!
JWT_SECRET="change_me_to_random_string_123"

# Port (Railway sets this automatically)
PORT=3001

# Environment
NODE_ENV=production

# ─── Telegram Bot ─────────────────────────────────────────────────
# Токен бота (уже вшит в код, но можно переопределить)
TELEGRAM_BOT_TOKEN="8752510903:AAG96QJx3X4Ve8OAAcCBiV_oWh28bBzziT4"

# ОБЯЗАТЕЛЬНО: Chat ID для отправки чеков и отчётов
# Как получить: напишите вашему боту /start в Telegram,
# затем откройте: https://api.telegram.org/bot<TOKEN>/getUpdates
# и найдите "chat":{"id": XXXXXXXX} — это ваш TELEGRAM_CHAT_ID
TELEGRAM_CHAT_ID="123456789"
